{
  "name": "checkquest",
  "version": "1.0.0",
  "description": "Autonomous exploratory QA agent for safe web testing, evidence collection, and structured reporting using TypeScript, Playwright, Gemini, and Zod.",
  "main": "index.js",
  "scripts": {
