{
  "name": "web-qa-agent",
  "version": "1.0.0",
  "description": "AI-assisted web QA agent for safe exploratory testing, evidence collection, and structured issue reporting using TypeScript, Playwright, and Gemini.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-chromium",
    "test:api": "playwright test --project=api",
    "report": "playwright show-report",
    "agent:check": "tsx agent/browser-check.ts",
    "agent:gemini-check": "tsx agent/gemini-sdk-check.ts",
    "agent:api-check": "tsx agent/gemini-api-check.ts",
    "agent:decide": "tsx agent/first-agent-decision.ts",
    "agent:navigation-check": "tsx agent/navigation-check.ts",
    "agent:navigation-choice": "tsx agent/navigation-choice-check.ts",
    "agent:navigation-visit": "tsx agent/navigation-visit-check.ts",
    "agent:run": "tsx agent/run-site-agent.ts",
    "agent:evaluation-check": "tsx agent/page-evaluation-check.ts",
    "agent:visited-links-check": "tsx agent/visited-links-check.ts",
    "agent:page-diagnostics-check": "tsx agent/page-diagnostics-check.ts",
    "agent:diagnostics-classification-check": "tsx agent/diagnostics-classification-check.ts",
    "agent:screenshot-check": "tsx agent/screenshot-check.ts",
    "agent:screenshot-trigger-check": "tsx agent/screenshot-trigger-check.ts",
    "agent:page-content-check": "tsx agent/page-content-check.ts",
    "agent:exploratory-qa-schema-check": "tsx agent/exploratory-qa-schema-check.ts",
    "agent:exploratory-qa-prompt-check": "tsx agent/exploratory-qa-prompt-check.ts",
    "agent:exploratory-qa-analysis-check": "tsx agent/exploratory-qa-analysis-check.ts",
    "agent:action-schema-check": "tsx agent/action-schema-check.ts",
    "agent:action-executor-check": "tsx agent/action-executor-check.ts",
    "agent:planner-schema-check": "tsx agent/planner-decision-schema-check.ts",
    "agent:planner-prompt-check": "tsx agent/planner-prompt-check.ts",
    "agent:planner-decision-check": "tsx agent/planner-decision-check.ts",
    "agent:planner-execution-check": "tsx agent/planner-execution-check.ts",
    "agent:exploratory-loop-check": "tsx agent/exploratory-loop-check.ts"
  },
  "keywords": [
    "qa",
    "automation",
    "playwright",
    "typescript",
    "testing",
    "ci"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "@google/genai": false,
    "protobufjs": false
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "zod": "^4.4.3"
  }
}
