{
  "name": "regulated-qa-automation-demo",
  "version": "1.0.0",
  "description": "Playwright and TypeScript QA automation demo with UI tests, API tests, CI execution, and QA documentation.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-chromium",
    "test:api": "playwright test --project=api",
    "report": "playwright show-report",
    "agent:check": "tsx agent/browser-check.ts",
    "agent:gemini-check": "tsx agent/gemini-sdk-check.ts",
    "agent:api-check": "tsx agent/gemini-api-check.ts",
    "agent:decide": "tsx agent/first-agent-decision.ts",
    "agent:navigation-check": "tsx agent/navigation-check.ts",
    "agent:navigation-choice": "tsx agent/navigation-choice-check.ts"
  },
  "keywords": [
    "qa",
    "automation",
    "playwright",
    "typescript",
    "testing",
    "ci"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "@google/genai": false,
    "protobufjs": false
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "zod": "^4.4.3"
  }
}
